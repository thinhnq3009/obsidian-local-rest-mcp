{
  "name": "obsidian-local-rest-mcp",
  "version": "0.2.0",
  "description": "A local STDIO MCP server that exposes Obsidian tools through the Obsidian Local REST API.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "obsidian-local-rest-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "start": "node dist/index.js",
    "prepack": "npm run build",
    "prepublishOnly": "npm run lint && npm test",
    "lint": "eslint .",
    "test": "vitest run --coverage"
  },
  "keywords": [
    "codex",
    "mcp",
    "obsidian",
    "rest-api",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thinhnq3009/obsidian-local-rest-mcp.git"
  },
  "homepage": "https://github.com/thinhnq3009/obsidian-local-rest-mcp#readme",
  "bugs": {
    "url": "https://github.com/thinhnq3009/obsidian-local-rest-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.7.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
